# Copy this file to .env:  cp .env.example .env

# --- REQUIRED: LLM Access via OpenRouter ---
# This key is provided for testing. Do NOT share or use for other projects.
OPENROUTER_API_KEY=PASTE_KEY_HERE

# --- REQUIRED: Google Search for team pages & DM discovery ---
# Serper.dev — used for finding team pages and decision makers via Google
# you can generate a key for free at serper.dev
SERPER_API_KEY=PASTE_KEY_HERE

# --- NOT NEEDED FOR THIS TASK ---
# These APIs are for phone enrichment and LinkedIn verification.
# Leave them empty — they are not part of your task.
ANTHROPIC_API_KEY=
ANTHROPIC_API_KEY_FALLBACK=
APIFY_API_KEY=
KASPR_API_KEY=
FULLENRICH_API_KEY=
